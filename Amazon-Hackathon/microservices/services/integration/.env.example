# Integration service — Google connector (OAuth + Gmail webhook producer + Calendar consumer)

# HTTP
PORT=8080

# Mongo (this service owns the campusflow_integration database)
MONGO_URI=mongodb://127.0.0.1:27017/campusflow_integration

# Kafka (comma-separated brokers)
KAFKA_BROKERS=kafka:9092

# Must match the gateway's JWT secret (used to sign/verify OAuth `state`)
JWT_SECRET=dev-only-insecure-secret-change-me

# Google OAuth (Calendar + Gmail readonly)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/auth/google/callback

# Gmail push via Google Cloud Pub/Sub
# projects/<gcp-project-id>/topics/<topic-id>
GMAIL_PUBSUB_TOPIC=
# Shared secret appended to the push URL: https://host/gmail/pubsub?token=<this>
GMAIL_PUBSUB_TOKEN=
# Only mail FROM these addresses is produced downstream (comma-separated)
GMAIL_ALLOWED_SENDERS=nagurok1234@gmail.com

# Where to bounce the OAuth callback back to
FRONTEND_URL=http://localhost:5173
