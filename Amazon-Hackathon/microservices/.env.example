# Copy to .env and fill in. Loaded into every service via docker-compose env_file.
JWT_SECRET=                 # long random string, shared by gateway + services

GEMINI_API_KEY=            # Google AI Studio key (blank => rule-based fallback)
GEMINI_MODEL=gemini-flash-lite-latest

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/auth/google/callback
GMAIL_PUBSUB_TOPIC=        # projects/<proj>/topics/<topic>
GMAIL_PUBSUB_TOKEN=        # shared secret in the push URL ?token=
GMAIL_ALLOWED_SENDERS=nagurok1234@gmail.com

DEEPGRAM_API_KEY=         # blank => voice disabled

FRONTEND_URL=http://localhost:5173
