# ---- Server ----
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ---- Database (MongoDB) ----
MONGODB_URI=             # TODO: your MongoDB connection string (Atlas or local, e.g. mongodb://127.0.0.1:27017/campusflow)

# ---- Amazon Bedrock (backend only — NEVER expose to frontend) ----
AWS_REGION=ap-south-1
BEDROCK_API_KEY=         # TODO: your Amazon Bedrock API key (Jul-2025 key feature)
# (or, if using IAM creds instead of a Bedrock API key:)
# AWS_ACCESS_KEY_ID=     # TODO
# AWS_SECRET_ACCESS_KEY= # TODO
BEDROCK_MODEL_ID=        # TODO: Claude model id, e.g. apac.anthropic.claude-3-5-haiku-...  (see AWS console)
#                          Leave BEDROCK_API_KEY + BEDROCK_MODEL_ID BLANK to run the
#                          rule-based fallback extractor (fully offline demo).

# ---- Google Calendar OAuth ----
GOOGLE_CLIENT_ID=        # TODO: from Google Cloud Console
GOOGLE_CLIENT_SECRET=    # TODO: from Google Cloud Console
GOOGLE_REDIRECT_URI=http://localhost:4000/auth/google/callback
#                          Leave Google vars BLANK to run Calendar sync in
#                          simulation mode (no real calendar writes).

# ---- Google Gemini (email categorizer + chatbot) ----
GEMINI_API_KEY=           # TODO: Google AI Studio API key (blank => rule-based fallback)
GEMINI_MODEL=gemini-2.5-flash-lite   # any Gemini model that supports PDF input

# ---- Deepgram (voice assistant: STT + TTS) ----
DEEPGRAM_API_KEY=         # from https://console.deepgram.com (blank => voice disabled)
DEEPGRAM_STT_MODEL=nova-2
DEEPGRAM_TTS_MODEL=aura-asteria-en

# ---- Gmail push notifications (Pub/Sub) ----
# Gmail publishes inbox changes to this Cloud Pub/Sub topic; a push subscription
# then POSTs to <PUBLIC_URL>/gmail/pubsub?token=<GMAIL_PUBSUB_TOKEN>.
GMAIL_PUBSUB_TOPIC=        # projects/<gcp-project-id>/topics/<topic-id>
GMAIL_PUBSUB_TOKEN=        # shared secret added to the push URL (?token=...)
GMAIL_ALLOWED_SENDERS=nagurok1234@gmail.com   # comma-separated; only these senders are ingested
#                          Leave GMAIL_PUBSUB_TOPIC BLANK to disable Gmail push.

# ---- ngrok tunnel (public HTTPS for the Pub/Sub webhook) ----
# `npm run dev:tunnel` boots the server + opens an HTTPS tunnel and prints the URL.
NGROK_AUTHTOKEN=          # from https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_DOMAIN=             # optional reserved domain for a stable URL across restarts

# ---- Auth / sessions ----
JWT_SECRET=              # TODO: a long random string
